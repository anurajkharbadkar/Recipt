# =============================================================
# Digital Pavti Book - API Environment Variables
# Copy this file to .env and fill in your values
# =============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3001
BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://pavti_user:pavti_password@localhost:5432/pavti_db?schema=public"

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-refresh-secret-too-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── MSG91 (SMS / OTP) ─────────────────────────────────────────
# Get from https://msg91.com
MSG91_API_KEY=
MSG91_SENDER_ID=PAVTIB
MSG91_OTP_TEMPLATE_ID=

# ── WhatsApp Business Cloud API ───────────────────────────────
# Get from https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ── Cloudflare R2 (File Storage) ──────────────────────────────
# S3-compatible object storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=pavti-files
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── Razorpay (Payments) ────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
